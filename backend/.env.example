# ==============================================================================
# 1. PRE-CONFIGURED DEFAULTS
# These values are standard for local development. 
# You generally do not need to change these to get the app running.
# ==============================================================================

# Server Configuration
# Options: development, production, test
NODE_ENV=development
PORT=5000
BASE_URL=http://localhost:5000


# ==============================================================================
# 2. REQUIRED USER-SPECIFIC CONFIGURATION
# You MUST provide your own values for these variables in your local .env file.
# ==============================================================================

# Database
# Instructions: Paste your MongoDB connection string (Local or Atlas)
MONGODB_URI=your_mongodb_connection_string_here

# Authentication
# Instructions: Generate a random string for these. 
# Tip: Run `openssl rand -base64 32` in your terminal to generate a secure key.
ACCESS_TOKEN_SECRET=your_access_token_secret_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

